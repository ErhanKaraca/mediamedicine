{
  "name": "@mediamedicine/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "build": "pnpm --filter @mediamedicine/shared build && wrangler deploy --dry-run --outdir=dist --env production",
    "build:ci": "pnpm --filter @mediamedicine/shared build && wrangler deploy --dry-run --outdir=dist --env production",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "openapi:export": "tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.4",
    "@mediamedicine/shared": "workspace:*",
    "@supabase/supabase-js": "^2.49.1",
    "hono": "^4.7.4",
    "jose": "^6.0.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.7.5",
    "@cloudflare/workers-types": "^4.20250224.0",
    "@mediamedicine/config": "workspace:*",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "~3.0.7",
    "wrangler": "^3.109.1"
  }
}
