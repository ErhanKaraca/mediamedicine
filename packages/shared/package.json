{
  "name": "@mediamedicine/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config/platform": {
      "types": "./dist/config/platform.d.ts",
      "import": "./dist/config/platform.js"
    },
    "./config/feed": {
      "types": "./dist/config/feed.d.ts",
      "import": "./dist/config/feed.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./edge-map": {
      "types": "./dist/edge-map.d.ts",
      "import": "./dist/edge-map.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@mediamedicine/config": "workspace:*",
    "typescript": "^5.7.2"
  }
}
